# =============================================================================
# ksj-wp-func — environment variables
# Copy this file to local.settings.json Values section for local development,
# or set as Azure Function App Settings in production.
# =============================================================================


# =============================================================================
# Azure Storage  (required)
# =============================================================================

# Full connection string for Azure Storage Account (Table + Queue + Blob).
# For local dev use the Azurite emulator connection string:
# DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=...;BlobEndpoint=http://127.0.0.1:10000/devstoreaccount1;...
STORAGE=DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT;AccountKey=YOUR_KEY;EndpointSuffix=core.windows.net


# =============================================================================
# OpenAI  (direct — use this OR Azure OpenAI below, not both)
# =============================================================================

# OpenAI API key (sk-...)
OAI_API_KEY=sk-...

# OpenAI-compatible base URL. Change for proxies or Azure AI Foundry endpoints.
# Default: https://api.openai.com/v1
OAI_BASE_URL=https://api.openai.com/v1

# Text model for article generation. Default: gpt-4o-mini
OAI_MODEL=gpt-4o-mini

# Image model for /api/generate-image. Default: gpt-image-1
OAI_IMAGE_MODEL=gpt-image-1


# =============================================================================
# Azure OpenAI  (use this OR OpenAI above, not both)
# =============================================================================

# Azure OpenAI resource endpoint URL (e.g. https://MY-RESOURCE.openai.azure.com)
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com

# Azure OpenAI API key
AZURE_OPENAI_API_KEY=your-azure-openai-key

# Text deployment name (model deployment in Azure portal)
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# API version for chat/completion calls
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Image deployment name (DALL-E 3 or gpt-image-1 deployment).
# Leave blank to use the OpenAI image endpoint instead.
AZURE_OPENAI_IMAGE_DEPLOYMENT=

# API version for image generation calls. Falls back to AZURE_OPENAI_API_VERSION if not set.
AZURE_OPENAI_API_VERSION_IMAGES=2024-02-15-preview

# Force which image provider to use: "azure" | "openai" | "" (auto-detect).
# Auto-detect: uses Azure if AZURE_OPENAI_IMAGE_DEPLOYMENT is set, else OpenAI.
FORCE_IMAGE_PROVIDER=


# =============================================================================
# LLM behaviour
# =============================================================================

# HTTP timeout (seconds) for LLM API calls. Default: 1500
LLM_HTTP_TIMEOUT=1500

# Max retries on LLM HTTP errors. Default: 3
LLM_MAX_RETRIES=3

# Exponential back-off base delay (seconds) between LLM retries. Default: 1.0
LLM_RETRY_BASE_DELAY=1.0

# Whether to use JSON Schema mode in LLM calls. 1=enabled (default), 0=disabled.
USE_JSON_SCHEMA=1

# Hard cap on output tokens sent to LLM per call. Default: 25000
WP_MAX_TOKENS=25000

# Force short output mode (for cost/speed testing). Default: false
FORCE_SHORT_MODE=false


# =============================================================================
# Article generation
# =============================================================================

# Article generation mode: "mega" (entire article in 1 LLM call, default)
# or "tick" (one section per HTTP call, driven by Power Automate).
ARTICLE_MODE=mega

# Default target word count when not supplied in the request. Default: 5000
WP_DEFAULT_WORDS=5000

# Minimum accepted word count (requests clamped to this floor). Default: 3000
WP_MIN_WORDS=3000

# Maximum accepted word count (requests clamped to this ceiling). Default: 15000
WP_MAX_WORDS=15000

# Word cap applied inside mega mode before inflation. Default: 4000
MEGA_MAX_WORDS=4000

# Number of sections generated per batch in mega mode. Default: 4
MEGA_BATCH_SIZE=4


# =============================================================================
# WordPress  (required for tag ID resolution and article publishing)
# =============================================================================

# WordPress REST API base URL, e.g. https://ksj.lv/wp-json/wp/v2
WP_API_BASE=https://YOUR-SITE.com/wp-json/wp/v2

# Authentication scheme: "jwt" (default) or "basic"
WP_AUTH_SCHEME=jwt

# JWT token for WP REST API (used when WP_AUTH_SCHEME=jwt)
WP_TOKEN=your-jwt-token

# Pre-encoded Basic auth credential: base64("username:app-password").
# Used when WP_AUTH_SCHEME=basic. If blank, WP_USER + WP_APP_PASSWORD are used.
WP_BASIC_AUTH_B64=

# WordPress username (used with WP_APP_PASSWORD when WP_BASIC_AUTH_B64 is blank)
WP_USER=

# WordPress application password (Settings → Users → Application Passwords)
WP_APP_PASSWORD=

# Max retries for WP REST API calls. Default: 3
WP_MAX_RETRIES=3

# Base delay (seconds) for WP API retry back-off. Default: 1.0
WP_RETRY_BASE_DELAY=1.0


# =============================================================================
# Content / tags
# =============================================================================

# Max number of tags assigned per article. Default: 3
PER_POST_TAG_LIMIT=3

# Strict anchor-link matching (1=on, 0=off). Default: 1
ANCHOR_STRICT=1

# Path to the tag whitelist JSON file. Default: cfg_dir/tags.json
TAG_WHITELIST_PATH=cfg_dir/tags.json

# Path to the anchor map JSON file. Default: cfg_dir/anchor_map.json
ANCHOR_MAP_PATH=cfg_dir/anchor_map.json


# =============================================================================
# Redis  (optional — used to cache SerpApi responses, 48 h TTL)
# =============================================================================

# Redis hostname (Azure Cache for Redis or self-hosted)
REDIS_HOST=YOUR-CACHE.redis.cache.windows.net

# Redis port. Default: 6380 (TLS)
REDIS_PORT=6380

# Redis access key / password
REDIS_PASSWORD=your-redis-primary-key

# Redis database index. Default: 0
REDIS_DB=0


# =============================================================================
# SerpApi  (optional — keyword enrichment via Google Search results)
# =============================================================================

# SerpApi API key. Calls are cached in Redis for 48 h; capped at 200/month.
# Leave blank to disable keyword enrichment.
SERPAPI_KEY=your-serpapi-key


# =============================================================================
# SEO image metadata
# =============================================================================

# Primary SEO keyword injected into image alt text when not already present.
# Default: datu sinhronizācija
KSJ_SEO_KEYWORD=datu sinhronizācija

# Sentence appended to image descriptions for SEO context.
KSJ_SEO_DESC_SUFFIX=Bez dublikātiem, uzlabota datu kvalitāte un uzticami atjauninājumi.

# Image resize strategy for the 1200×630 social header output.
# Options: auto (default) | cover (crop to fill) | contain (letterbox)
IMAGE_FIT_MODE=auto


# =============================================================================
# Facebook / external links
# =============================================================================

# CTA link used as a fallback in Facebook post copy when no WP slug is available.
BOOK_LINK=https://book.jurjans.dev
